{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Consumer lag per partition — event-consumers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kafka_consumergroup_lag{consumergroup=\"event-consumers\"}",
          "legendFormat": "{{topic}} · p{{partition}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Total lag (all partitions)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" },
        "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 1000 } ] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(kafka_consumergroup_lag{consumergroup=\"event-consumers\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consume rate (messages/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short", "min": 0 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(kafka_consumergroup_current_offset{consumergroup=\"event-consumers\"}[1m]))",
          "legendFormat": "consumed/sec",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["kafka", "lag"],
  "templating": { "list": [] },
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "title": "Kafka Consumer Lag",
  "uid": "kafka-lag",
  "version": 1
}
