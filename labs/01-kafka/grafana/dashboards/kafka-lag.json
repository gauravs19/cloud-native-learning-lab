{
  "annotations": { "list": [] },
  "editable": true,
  "style": "dark",
  "graphTooltip": 1,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["kafka", "lag"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "title": "Kafka · Consumer Lag",
  "uid": "kafka-lag",
  "version": 5,
  "panels": [
    {
      "type": "stat",
      "title": "Published events",
      "description": "Total messages written to the topic (sum of partition end offsets).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#3D71D9" } } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kafka_topic_partition_current_offset{topic=\"events\"}) or vector(0)", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Consumed events",
      "description": "Total messages consumed by the group (sum of committed offsets).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "#56A64B" } } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kafka_consumergroup_current_offset{consumergroup=\"event-consumers\",topic=\"events\"}) or vector(0)", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Lag",
      "description": "Published minus consumed — the current backlog.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": {
        "unit": "short", "decimals": 0,
        "color": { "mode": "thresholds" },
        "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "#F2CC0C", "value": 200 },
          { "color": "#FF780A", "value": 2000 },
          { "color": "red", "value": 20000 }
        ] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(kafka_consumergroup_lag{consumergroup=\"event-consumers\"}) or vector(0)", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Lag by partition",
      "description": "Per-partition backlog over time.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 0, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "kafka_consumergroup_lag{consumergroup=\"event-consumers\"}", "legendFormat": "partition {{partition}}", "refId": "A" } ]
    }
  ]
}
